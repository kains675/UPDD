def _load_forcefield(md_dir: str) -> Tuple[ForceField, List[str], List[str]]:
    """Replicate the MM-GBSA ForceField assembly: amber14 + HFE multivalent
    + GBn2 + any ncAA XML + ncAA Hydrogens defs, reading from the sibling
    `params/` directory.
    """
    ff_files = [
        "amber14-all.xml",
        "amber/tip3p_HFE_multivalent.xml",
        "implicit/gbn2.xml",
    ]
    params_dir = os.path.join(os.path.dirname(md_dir), "params")
    ncaa_xmls: List[str] = []
    ncaa_hydrogens: List[str] = []
    for mf in sorted(glob.glob(os.path.join(params_dir, "*_params_manifest.json"))):
        try:
            with open(mf, "r", encoding="utf-8") as _mf:
                manifest = json.load(_mf)
            xml_path = manifest.get("xml_path", "")
            if xml_path and os.path.exists(xml_path):
                ncaa_xmls.append(xml_path)
            h_path = manifest.get("hydrogens_path", "")
            if h_path and os.path.exists(h_path):
                ncaa_hydrogens.append(h_path)
        except Exception as _me:
            print(f"  [!] manifest 파싱 실패 ({os.path.basename(mf)}): {_me}")
    for h_xml in ncaa_hydrogens:
        try:
            app.Modeller.loadHydrogenDefinitions(h_xml)
        except Exception:
            pass
    try:
        ff = ForceField(*ff_files, *ncaa_xmls)
    except Exception as _ff_err:
        print(f"  [!] ncAA XML 로드 실패 — amber14 only 로 폴백: {_ff_err}")
        ff = ForceField(*ff_files)
    return ff, ncaa_xmls, ncaa_hydrogens


def _load_cofactor_mol2(target_id: str) -> List:
    """R-17 G6 parity with MM-GBSA: load `cofactor_ff_parameters` from
    the target_card so mol2-based cofactors (GNP/ATP/…) survive the
    OpenMM Modeller bond-inference step.
    """
    if not target_id:
        return []
    try:
        sys.path.append(os.path.join(
            os.path.dirname(os.path.abspath(__file__)), os.pardir, "utils"))
        from run_restrained_md import load_cofactor_ff_parameters  # type: ignore
        from utils_common import load_target_card  # type: ignore
        cards_dir = os.path.join(
            os.path.dirname(os.path.abspath(__file__)),
            os.pardir, "target_cards",
        )
        card = load_target_card(target_id, cards_dir=cards_dir)
        return [
            (r, p) for r, p in load_cofactor_ff_parameters(card)
            if p.endswith(".mol2")
        ]
    except (FileNotFoundError, ValueError, ImportError) as _tc_err:
        print(f"  [R-17 G6][WARN] target_card '{target_id}' 로드 실패 "
              f"({_tc_err}) — cofactor FF 등록 생략")
        return []


def main():
    parser = argparse.ArgumentParser(
        description="MM-PBSA ΔG — AmberTools pbsa on Fix 4 minimized geometries.",
    )
    parser.add_argument("--md_dir",         required=True,
                        help="MD snapshot directory (same shape as run_mmgbsa.py).")
    parser.add_argument("--outputdir",      required=True,
                        help="MM-PBSA 결과 출력 디렉토리.")
    parser.add_argument("--ncaa_elem",      default="none",
                        help="ncAA 핵심 원소 (예: Si, F, 기본 none).")
    parser.add_argument("--si_radius",      type=float, default=2.10,
                        help="Si GB 반경 (legacy, 기본 2.10).")
    parser.add_argument("--receptor_chain", default="A",
                        help="Receptor chain ID (기본 A).")
    parser.add_argument("--binder_chain",   default="B",
                        help="Binder chain ID (기본 B).")
    parser.add_argument("--target_id",      default="",
                        help="target_card stem (예: 2QKI / 6WGN) for cofactor FF.")
    parser.add_argument("--protocol",       default="1traj",
                        choices=("1traj",),
                        help="MM-PBSA protocol (현재 1traj 만 지원).")
    parser.add_argument("--ionic_strength", type=float,
                        default=PBSA_DEFAULTS["ionic_strength_M"],
                        help="pbsa 이온 세기 (M, 기본 0.150).")
    parser.add_argument("--n_snaps",        type=int, default=0,
                        help="0 = all; 양수 = 앞에서부터 N 개만 (dry-run/test 용).")
    parser.add_argument("--max_snaps",      type=int, default=None,
                        help="Alias of --n_snaps (Track B validation convention). "
                             "Takes precedence if both are given.")
    parser.add_argument("--dry_run",        action="store_true",
                        help="MMPBSA.py 호출 없이 입력 파일 / 명령줄만 점검.")
    args = parser.parse_args()

    os.makedirs(args.outputdir, exist_ok=True)

    amberhome = _find_amberhome()
    print(f"[MM-PBSA ΔG Calculation]")
    print(f"  AMBERHOME   : {amberhome}")
    print(f"  solver      : ambertools_pbsa (MMPBSA.py single-traj)")
    print(f"  protocol    : {args.protocol}")
    print(f"  md_dir      : {args.md_dir}")
    print(f"  outputdir   : {args.outputdir}")

    ff, ncaa_xmls, ncaa_hydrogens = _load_forcefield(args.md_dir)
    if ncaa_xmls:
        print(f"  ncAA XML    : {[os.path.basename(x) for x in ncaa_xmls]}")
    cofactor_mol2 = _load_cofactor_mol2(args.target_id)
    if cofactor_mol2:
        print(f"  cofactor mol2: {[r for r,_ in cofactor_mol2]}")

    # Register cofactor GAFF templates on the main-process ff so
    # Modeller / createSystem do not fail at cofactor residues.
    if cofactor_mol2:
        try:
            sys.path.append(os.path.join(
                os.path.dirname(os.path.abspath(__file__)), os.pardir, "utils"))
            from run_restrained_md import register_cofactor_templates  # type: ignore
            register_cofactor_templates(ff, cofactor_mol2)
        except ImportError:
            pass

    pdb_files = sorted(glob.glob(os.path.join(args.md_dir, "*_final.pdb")))
    if not pdb_files:
        pdb_files = sorted(glob.glob(os.path.join(args.md_dir, "*.pdb")))
    if not pdb_files:
        print(f"[!] PDB 파일 없음: {args.md_dir}")
        return
    _cap = args.max_snaps if args.max_snaps is not None else args.n_snaps
    if _cap and _cap > 0:
        pdb_files = pdb_files[:_cap]

    print(f"  대상 PDB    : {len(pdb_files)}개")
    print(f"  ionic 세기  : {args.ionic_strength} M")

    pbsa_cfg = dict(PBSA_DEFAULTS)
    pbsa_cfg["ionic_strength_M"] = args.ionic_strength

    if args.dry_run:
        print("\n[DRY RUN] Constructing MMPBSA.py command skeleton only.")
        sample_work = os.path.join(args.outputdir, "tmp_pbsa", "DRYRUN")
        os.makedirs(sample_work, exist_ok=True)
        input_file = os.path.join(sample_work, "pbsa.in")
        _write_pbsa_input(input_file, pbsa_cfg)
        print(f"  input file : {input_file}")
        with open(input_file, "r", encoding="utf-8") as _f:
            print("----- pbsa.in -----")
            print(_f.read())
            print("-------------------")
        sample_cmd = [
            "MMPBSA.py", "-O",
            "-i", input_file,
            "-o", os.path.join(sample_work, "FINAL_RESULTS_MMPBSA.dat"),
            "-cp", "<cplx.prmtop>",
            "-rp", "<rec.prmtop>",
            "-lp", "<lig.prmtop>",
            "-y",  "<cplx.inpcrd>",
        ]
        print(f"  sample cmd : {' '.join(sample_cmd)}")
        print(f"  AMBERHOME  : {amberhome}")
        return

    all_results: List[Dict] = []
    for pdb_path in pdb_files:
        try:
            res = calc_mmpbsa_1traj(
                pdb_path, args.outputdir, ff,
                args.ncaa_elem, args.si_radius,
                receptor_chain=args.receptor_chain,
                binder_chain=args.binder_chain,
                pbsa_cfg=pbsa_cfg, amberhome=amberhome,
                cofactor_mol2_paths=cofactor_mol2,
                ncaa_xmls=ncaa_xmls,
            )
        except Exception as _err:
            print(f"  [!] snap 실패 ({os.path.basename(pdb_path)}): "
                  f"{_err.__class__.__name__}: {_err}")
            res = None
        if res is not None:
            all_results.append(res)

    if not all_results:
        print("\n[!] 계산된 결과 없음")
        return

    all_results.sort(key=lambda r: r["delta_g_kcal"])
    _n_fallback = sum(1 for r in all_results if r.get("fallback_triggered"))
    summary = {
        "schema_version":   "0.6.9",
        "protocol_variant": args.protocol,
        "solvent_model":    "pbsa",
        "gb_model":         "n2",
        "fallback_triggered": _n_fallback > 0,
        "n_fallback_snaps":  _n_fallback,
        "pbsa_config": {
            "solver":           "ambertools_pbsa",
            "ionic_strength_M": args.ionic_strength,
            "temperature_K":    pbsa_cfg["temperature_K"],
            "epsilon_solute":   pbsa_cfg["epsilon_solute"],
            "epsilon_solvent":  pbsa_cfg["epsilon_solvent"],
            "cavity_surften":   pbsa_cfg["cavity_surften"],
            "cavity_offset":    pbsa_cfg["cavity_offset"],
            "inp":              pbsa_cfg["inp"],
            "ipb":              pbsa_cfg["ipb"],
            "radiopt":          pbsa_cfg["radiopt"],
            "amberhome":        amberhome,
        },
        "ncaa_elem":  args.ncaa_elem,
        "si_radius":  args.si_radius,
        "n_calc":     len(all_results),
        "mean_dg":    float(np.mean([r["delta_g_kcal"] for r in all_results])),
        "best_dg":    float(all_results[0]["delta_g_kcal"]),
        "results":    all_results,
    }
    summary_path = os.path.join(args.outputdir, "mmpbsa_summary.json")
    with open(summary_path, "w", encoding="utf-8") as f:
        json.dump(summary, f, indent=2)

    print(f"\n  [ΔG_bind(PBSA) 순위]")
    print(f"  {'순위':<4} {'스냅샷':<42} {'ΔG (kcal/mol)':>14}")
    print("  " + "-" * 62)
    for i, r in enumerate(all_results, 1):
        flag = "✅" if r["favorable"] else "⚠️ "
        print(f"  {i:<4} {r['snapshot'][:40]:<42} {r['delta_g_kcal']:>+12.4f}  {flag}")
    print(f"\n  평균 ΔG : {summary['mean_dg']:+.4f} kcal/mol")
    print(f"  최선 ΔG : {summary['best_dg']:+.4f} kcal/mol")
    print(f"  요약 저장 : {summary_path}")


if __name__ == "__main__":
    main()
