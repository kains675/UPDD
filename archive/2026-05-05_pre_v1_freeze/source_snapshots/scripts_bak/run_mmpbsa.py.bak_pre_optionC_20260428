# --------------------------------------------------------------------
# PBSA defaults (AmberTools pbsa input namelist values)
# --------------------------------------------------------------------
# Literature defaults (Homeyer & Gohlke 2012 Table 1, Wang 2006 ipb=2).
# Conservative choices:
#   - istrng 0.150 M  : physiological ionic strength
#   - inp 2           : SASA-based nonpolar (surften + offset)
#   - ipb 2           : smooth dielectric boundary via cubic spline
#   - radiopt 0       : use prmtop intrinsic radii (mbondi from tleap
#                       via amber14SB force field; matches MM-GBSA
#                       radius set to the extent the prmtop carries it).
#   - epsin 1.0, epsout 80.0 : standard vacuum-in / water-out.
PBSA_DEFAULTS = {
    "ionic_strength_M":   0.150,
    "temperature_K":      300.0,
    "epsilon_solute":     1.0,
    "epsilon_solvent":    80.0,
    "cavity_surften":     0.0378,   # kcal/mol/Å² (Tan 2007)
    "cavity_offset":     -0.5692,   # kcal/mol (Tan 2007)
    "inp":                2,
    "ipb":                2,
    # radiopt=0 : read radii from the prmtop. We apply mbondi2 via
    # parmed's `tools.changeRadii` *before* writing the prmtop (see
    # `_system_to_amber`) so the RADIUS_SET field carries valid values.
    #
    # Rationale: parmed.openmm.load_topology on a vacuum OpenMM System
    # emits a prmtop with all-zero RADII (no GB force is present to
    # carry them). `radiopt=1` (pbsa-internal table) chokes on atom
    # types parmed uses (e.g. "N1"), raising
    # `PB Bomb in pb_aaradi(): No radius assigned for atom ...`.
    # Baking mbondi2 radii into the prmtop with parmed is element-based
    # (plus H-bond-context for mbondi2) and therefore robust to atom-type
    # labelling quirks.
    "radiopt":            0,
}


# --------------------------------------------------------------------
# AmberTools invocation helpers
# --------------------------------------------------------------------
def _find_amberhome() -> str:
    """Locate AMBERHOME. Prefer environment variable; fall back to the
    active conda prefix if tleap is discoverable.
    """
    env = os.environ.get("AMBERHOME")
    if env and os.path.isdir(env):
        return env
    tleap = shutil.which("tleap")
    if tleap:
        # tleap lives in $AMBERHOME/bin/tleap
        return os.path.dirname(os.path.dirname(os.path.abspath(tleap)))
    raise RuntimeError(
        "AMBERHOME not set and `tleap` not on PATH. "
        "Activate the qmmm or md_simulation conda env before running."
    )


def _write_pbsa_input(path: str, pbsa_cfg: Dict) -> None:
    """Write a minimal MMPBSA.py input file that disables GB and runs a
    single-frame PB + SASA evaluation.
    """
    # use_sander=1 routes the PB solve through external sander + pbsa
    # (the full AmberTools pbsa solver). The default (mmpbsa_py_energy)
    # silently drops the EPB polar term for systems that exceed its
    # limited feature set — observed as EPB = 0.0 in the Differences
    # block. Forcing sander avoids this failure mode.
    content = f"""MM-PBSA single-frame PB + SASA (run_mmpbsa.py)
&general
  startframe=1, endframe=1, interval=1,
  keep_files=0, verbose=1,
  use_sander=1,
  strip_mask=":WAT,Cl*,CIO,Cs+,IB,K*,Li+,Na+,Rb+,CS,RB,NA,F,CL",
/
&pb
  istrng={pbsa_cfg['ionic_strength_M']},
  inp={pbsa_cfg['inp']},
  ipb={pbsa_cfg['ipb']},
  radiopt={pbsa_cfg['radiopt']},
  indi={pbsa_cfg['epsilon_solute']},
  exdi={pbsa_cfg['epsilon_solvent']},
  cavity_surften={pbsa_cfg['cavity_surften']},
  cavity_offset={pbsa_cfg['cavity_offset']},
/
"""
    with open(path, "w", encoding="utf-8") as f:
        f.write(content)


# --------------------------------------------------------------------
# OpenMM System → AMBER prmtop/inpcrd via parmed
# --------------------------------------------------------------------
def _positions_to_ndarray(positions) -> "np.ndarray":
    """Normalize OpenMM positions (any of: Quantity[Vec3], list[Quantity[Vec3]],
    list[Vec3]) into a plain (N, 3) float64 ndarray in Angstrom, which is
    what parmed.Structure.coordinates expects.

    parmed's `Structure.coordinates` setter calls `np.asanyarray(value,
    dtype=np.float64)` which fails when the list contains Quantity
    objects that do not convert element-wise to float. We therefore
    pre-extract nanometer values and scale to Angstrom (parmed's native
    coordinate unit).
    """
    # Convert each element to nm value then scale to Å.
    out = np.empty((len(positions), 3), dtype=np.float64)
    for i, p in enumerate(positions):
        # p may be Quantity or Vec3; either way, stripping unit.nanometer yields
        # a Vec3 whose .x/.y/.z are plain floats.
        try:
            p_nm = p.value_in_unit(unit.nanometer)
        except AttributeError:
            p_nm = p  # already a Vec3 in nm
        out[i, 0] = float(p_nm.x) * 10.0
        out[i, 1] = float(p_nm.y) * 10.0
        out[i, 2] = float(p_nm.z) * 10.0
    return out


def _patch_missing_bond_types(structure) -> int:
    """Fill any bond with ``type is None`` using a default amide-bond
    BondType (k=490 kcal/mol/Å², r0=1.335 Å — amber14SB peptide C–N).

    Returns the number of bonds patched.

    Context
    -------
    ``parmed.openmm.load_topology`` inspects ``HarmonicBondForce`` and only
    assigns a ``BondType`` to bonds it finds there. For ncAA peptide runs
    (e.g. MTR in the Cp4 binder), OpenMM's ``createSystem`` silently drops
    inter-residue peptide bonds whose atom-type pair (e.g. GAFF2 ``C4`` ↔
    amber14 ``N`` or amber14 ``C`` ↔ GAFF2 ``N1``) has no matching
    ``<Bond>`` entry in any loaded XML. The Topology retains the bond
    (OBBO inference gives 215 bonds), but ``HarmonicBondForce`` carries
    only 213; parmed then stores a ``Bond`` with ``type=None`` and trips
    ``AmberParm._xfer_bond_info`` with ``'NoneType' object has no
    attribute 'used'``.

    The ranking-regime fix (R-11) is to splice a canonical amide
    parameter into these cross-residue bonds. Because the same bonds
    appear in both the Complex and the Ligand subsystems (both carry
    MTR3–GLN4 and VAL2–MTR3 peptide links), the bonded stretch energy
    cancels in the 1-trajectory ΔG = E_cplx − E_rec − E_lig difference
    (Genheden & Ryde 2015 §2.1). Receptor has no MTR, so the asymmetry
    is irrelevant there.

    Rationale for parameter choice
    ------------------------------
    amber14SB's standard protein backbone bond: C–N, k=490 kcal/mol/Å²,
    r0=1.335 Å (Hornak 2006 / Maier 2015). ncAA side-chain–backbone
    joins that actually exist in native amide geometry are within 1–2%
    of this value, so any residual stretch energy (after minimization
    already flattened it) is well below PB numerical noise.
    """
    from parmed import BondType
    n_missing = sum(1 for b in structure.bonds if b.type is None)
    if n_missing == 0:
        return 0
    amide_type = BondType(k=490.0, req=1.335, list=structure.bond_types)
    structure.bond_types.append(amide_type)
    for b in structure.bonds:
        if b.type is None:
            b.type = amide_type
    return n_missing


def _system_to_amber(topology, system, positions, out_prefix: str,
                     _retry_with_patch: bool = True) -> Tuple[str, str, bool]:
    """Convert an OpenMM (topology, system, positions) triple into an
    AMBER prmtop + inpcrd pair. Returns (prmtop_path, inpcrd_path, patched).

    parmed.openmm.load_topology consumes the OpenMM Topology + System and
    emits a parmed Structure carrying the Amber-style parameters; the
    Structure can then be written via `save(..., format='amber')` to
    produce prmtop + rst7.

    Positions are normalized into a plain ndarray (Å) before assignment
    because parmed's setter cannot ingest a list of Quantity/Vec3 objects
    whose `__float__` does not return a plain float (raises
    `ValueError: setting an array element with a sequence.`).

    ncAA fallback (Track B Step B2, 2026-04-23)
    -------------------------------------------
    When ncAA residues (GAFF2-typed, e.g. MTR) border amber14SB residues,
    ``createSystem`` can silently drop the peptide-junction bonds whose
    atom-type pair has no ``<Bond>`` entry in any loaded XML. The saved
    ``AmberParm`` then trips with ``'NoneType' object has no attribute
    'used'`` inside ``_xfer_bond_info``. On that specific exception we
    patch the missing bond types with a canonical amide parameter (see
    ``_patch_missing_bond_types``) and retry. The ``patched`` boolean
    flows up to the per-snap JSON as ``fallback_triggered`` so the Path
    agent can filter patched vs un-patched runs.
    """
    from parmed.openmm import load_topology
    # Build structure first (without positions), then override coordinates
    # with the normalized ndarray.
    structure = load_topology(topology, system=system)
    structure.coordinates = _positions_to_ndarray(positions)
    prmtop = out_prefix + ".prmtop"
    inpcrd = out_prefix + ".inpcrd"

    patched = False
    try:
        # overwrite=True since we may re-run for failed snaps.
        structure.save(prmtop, format="amber", overwrite=True)
    except AttributeError as exc:
        # The specific ncAA-junction failure: ``bond.type is None``
        # triggers ``'NoneType' object has no attribute 'used'`` inside
        # ``AmberParm._xfer_bond_info``. Any other AttributeError is a
        # genuine programming error and we re-raise.
        if "used" not in str(exc) or not _retry_with_patch:
            raise
        n_patched = _patch_missing_bond_types(structure)
        if n_patched == 0:
            # The error cause was something else than missing bond types —
            # cannot auto-recover.
            raise
        print(f"    [fallback] patched {n_patched} missing ncAA "
              f"peptide-junction bond type(s); retrying save")
        # Discard any half-written prmtop and retry with a fresh Structure
        # (parmed's internal caches may have inconsistent state after the
        # aborted ``AmberParm.from_structure``). We rebuild from scratch.
        structure = load_topology(topology, system=system)
        structure.coordinates = _positions_to_ndarray(positions)
        _patch_missing_bond_types(structure)
        structure.save(prmtop, format="amber", overwrite=True)
        patched = True

    structure.save(inpcrd, format="rst7", overwrite=True)
    # Bake mbondi2 radii into the just-written prmtop. parmed's tool is
    # element-based and works off the raw prmtop, so we re-open, run
    # changeRadii, and write back. Using a temporary AmberParm instance
    # avoids touching the already-saved inpcrd.
    from parmed import load_file as _pmd_load
    from parmed.tools import changeRadii
    parm = _pmd_load(prmtop)
    changeRadii(parm, "mbondi2").execute()
    parm.write_parm(prmtop)
    return prmtop, inpcrd, patched


# --------------------------------------------------------------------
# MMPBSA.py execution + output parsing
# --------------------------------------------------------------------
# Parser regex for `FINAL_RESULTS_MMPBSA.dat` DELTAS TOTAL line. The
# "Differences" block lists per-energy-term deltas; we need the PB totals
# (polar EPB, nonpolar ENPOLAR / EDISPER, cumulative DELTA TOTAL).
_RE_TOTAL = re.compile(r"^DELTA TOTAL\s+([-\d.]+)")
_RE_EPB   = re.compile(r"^EPB\s+([-\d.]+)\s+([-\d.]+)")
_RE_ENPOLAR = re.compile(r"^ENPOLAR\s+([-\d.]+)\s+([-\d.]+)")
_RE_EDISPER = re.compile(r"^EDISPER\s+([-\d.]+)\s+([-\d.]+)")


def _run_mmpbsa_py(work_dir: str, cplx_prmtop: str, rec_prmtop: str,
                   lig_prmtop: str, cplx_mdcrd: str, pbsa_cfg: Dict,
                   amberhome: str) -> Optional[Dict]:
    """Invoke MMPBSA.py in single-trajectory mode. Returns parsed ΔG
    components (kcal/mol) or None on failure.

    Runs in a dedicated work_dir so `_MMPBSA_*` scratch files are
    isolated from concurrent snap-level invocations.
    """
    input_file = os.path.join(work_dir, "pbsa.in")
    _write_pbsa_input(input_file, pbsa_cfg)
    out_file = os.path.join(work_dir, "FINAL_RESULTS_MMPBSA.dat")

    env = os.environ.copy()
    env["AMBERHOME"] = amberhome
    env["PATH"] = os.path.join(amberhome, "bin") + os.pathsep + env.get("PATH", "")

    # 2026-04-23 fix: cwd=work_dir + relative paths conflict (MMPBSA.py treats
    # "outputs/.../pbsa.in" as relative to cwd=work_dir which doubles the path).
    # Pass absolute paths so cwd= is only used for _MMPBSA_*.mdin scratch files.
    cmd = [
        "MMPBSA.py", "-O",
        "-i", os.path.abspath(input_file),
        "-o", os.path.abspath(out_file),
        "-cp", os.path.abspath(cplx_prmtop),
        "-rp", os.path.abspath(rec_prmtop),
        "-lp", os.path.abspath(lig_prmtop),
        "-y",  os.path.abspath(cplx_mdcrd),
    ]
    try:
        result = subprocess.run(
            cmd, cwd=work_dir, env=env, capture_output=True,
            text=True, timeout=1800,  # 30 min per snap upper bound
        )
    except subprocess.TimeoutExpired:
        print(f"    [!] MMPBSA.py timeout (>30 min) in {work_dir}")
        return None

    if result.returncode != 0:
        print(f"    [!] MMPBSA.py returncode={result.returncode}")
        print(f"    [stderr head] {result.stderr[:400]}")
        return None
    if not os.path.exists(out_file):
        print(f"    [!] MMPBSA.py produced no output at {out_file}")
        return None

    return _parse_mmpbsa_output(out_file)


def _parse_mmpbsa_output(dat_path: str) -> Optional[Dict]:
    """Extract ΔG_bind (PB total) + components from FINAL_RESULTS_MMPBSA.dat.

    The deltas block is the last occurrence of "Differences" in the file;
    we scan forward from there and pick up EPB, ENPOLAR, EDISPER, and
    DELTA TOTAL lines.
    """
    with open(dat_path, "r", encoding="utf-8") as f:
        lines = f.readlines()

    # Locate the final "Differences (Complex - Receptor - Ligand)" section.
    diff_start = None
    for i, line in enumerate(lines):
        if "Differences" in line and "Complex" in line and "Ligand" in line:
            diff_start = i
    if diff_start is None:
        return None

    total = epb = enpolar = edisper = None
    for line in lines[diff_start:]:
        m = _RE_TOTAL.match(line)
        if m:
            total = float(m.group(1))
        m = _RE_EPB.match(line)
        if m:
            epb = float(m.group(1))
        m = _RE_ENPOLAR.match(line)
        if m:
            enpolar = float(m.group(1))
        m = _RE_EDISPER.match(line)
        if m:
            edisper = float(m.group(1))

    if total is None:
        return None
    return {
        "delta_g_kcal":       total,
        "delta_epb_kcal":     epb,
        "delta_enpolar_kcal": enpolar,
        "delta_edisper_kcal": edisper,
    }


# --------------------------------------------------------------------
# Single-snap driver (Fix 4 minimize → parmed → MMPBSA.py)
# --------------------------------------------------------------------
def calc_mmpbsa_1traj(pdb_path: str, output_dir: str, ff: ForceField,
                      ncaa_elem: str, si_radius: float,
                      receptor_chain: str = "A",
                      binder_chain: str = "B",
                      pbsa_cfg: Optional[Dict] = None,
                      amberhome: Optional[str] = None,
                      cofactor_mol2_paths: Optional[List] = None,
                      ncaa_xmls: Optional[List[str]] = None) -> Optional[Dict]:
    """Compute ΔG_bind(PBSA) for one snapshot, reusing the Fix 4 1-traj
    protocol (minimize complex once, freeze bound geometry for receptor
    and ligand).
    """
    pbsa_cfg = dict(PBSA_DEFAULTS, **(pbsa_cfg or {}))
    amberhome = amberhome or _find_amberhome()
    cofactor_mol2_paths = list(cofactor_mol2_paths or [])
    _vacuum_ncaa_xmls = list(ncaa_xmls or [])

    basename = os.path.basename(pdb_path).replace(".pdb", "")
    tmp_dir = os.path.join(output_dir, "tmp_pbsa", basename)
    os.makedirs(tmp_dir, exist_ok=True)

    print(f"\n  계산 [PBSA 1-traj]: {basename}")

    complex_lines, receptor_lines, ligand_lines = split_complex(
        pdb_path, receptor_chain, binder_chain,
    )
    if not receptor_lines or not ligand_lines:
        print(f"    [!] receptor/ligand 누락 — skip")
        return None

    cplx_pdb = os.path.join(tmp_dir, f"{basename}_complex.pdb")
    recv_pdb = os.path.join(tmp_dir, f"{basename}_receptor.pdb")
    lig_pdb  = os.path.join(tmp_dir, f"{basename}_ligand.pdb")
    write_temp_pdb(complex_lines,  cplx_pdb)
    write_temp_pdb(receptor_lines, recv_pdb)
    write_temp_pdb(ligand_lines,   lig_pdb)

    _min_iter = int(os.environ.get("UPDD_MMPBSA_MIN_ITER",
                                   os.environ.get("UPDD_MMGBSA_MIN_ITER", "5000")))
    _min_tol = float(os.environ.get("UPDD_MMPBSA_MIN_TOL",
                                    os.environ.get("UPDD_MMGBSA_MIN_TOL", "1.0")))

    # --- 1. Build + minimize complex under GBn2 (bound-state geometry) ---
    # Inject cofactor bonds (R-17 G6 parity with MM-GBSA path).
    try:
        pdb = PDBFile(cplx_pdb)
    except Exception as e:
        print(f"    [!] complex PDB 로드 실패: {e}")
        return None
    cplx_modeller = app.Modeller(pdb.topology, pdb.positions)
    if cofactor_mol2_paths:
        try:
            sys.path.append(os.path.join(
                os.path.dirname(os.path.abspath(__file__)), os.pardir, "utils"))
            from run_restrained_md import inject_cofactor_bonds  # type: ignore
            inject_cofactor_bonds(cplx_modeller, cofactor_mol2_paths)
        except ImportError:
            pass
    if binder_chain:
        cplx_modeller, _ = _apply_cyclic_bonds_mmgbsa(cplx_modeller, binder_chain)

    try:
        cplx_gb_system = ff.createSystem(
            cplx_modeller.topology,
            nonbondedMethod   = app.NoCutoff,
            constraints       = HBonds,
            soluteDielectric  = 1.0,
            solventDielectric = 78.5,
        )
    except Exception as e:
        print(f"    [!] Complex GB system 생성 실패: {e}")
        return None
    cplx_gb_system = apply_gb_radius_override(
        cplx_gb_system, cplx_modeller.topology, ncaa_elem, si_radius,
    )

    _pref = os.environ.get("UPDD_MMGBSA_PLATFORM", "CUDA")
    platform = None
    for name in (_pref, "CUDA", "OpenCL", "CPU"):
        try:
            platform = mm.Platform.getPlatformByName(name)
            break
        except Exception:
            continue
    if platform is None:
        platform = mm.Platform.getPlatformByName("CPU")

    integrator = mm.VerletIntegrator(1.0 * unit.femtoseconds)
    sim = Simulation(cplx_modeller.topology, cplx_gb_system, integrator, platform)
    sim.context.setPositions(cplx_modeller.positions)
    print(f"    [Fix4 min] {_min_iter} iter, tol={_min_tol} ({platform.getName()})")
    sim.minimizeEnergy(maxIterations=_min_iter, tolerance=_min_tol)
    min_state = sim.context.getState(getEnergy=True, getPositions=True)
    cplx_min_positions = min_state.getPositions(asNumpy=False)

    # --- 2. Build vacuum Systems (no GB) for prmtop export ---
    # AmberParm carries the bonded + LJ + Coulomb terms only; PB contributes
    # the solvation term separately via MMPBSA.py. We therefore strip GB
    # from the force field used for prmtop generation.
    #
    # IMPORTANT: do NOT pass `constraints=HBonds` here. HBonds rewrites the
    # bonded slot for H-containing bonds into Constraint objects, which
    # leaves the corresponding HarmonicBondForce entries with null bond
    # types. parmed.amber.AmberParm.from_structure then fails with
    # `'NoneType' object has no attribute 'used'` while transferring
    # bond info. MMPBSA.py is a single-point PB evaluator (no dynamics),
    # so omitting constraints has no physical consequence for ΔG_PBSA.
    def _build_vacuum(modeller, is_binder_side: bool):
        # Pull ncAA XMLs / HFE multivalent from the *parent* ff so MTR /
        # metal ions in the ligand / receptor retain parameters when we
        # rebuild the vacuum System. We mimic the loader in _load_forcefield
        # minus implicit/gbn2.xml.
        vac_ff_files = [
            "amber14-all.xml",
            "amber/tip3p_HFE_multivalent.xml",
        ]
        # ncAA XML parameters need to propagate from the caller.
        vac_ff = ForceField(*vac_ff_files, *_vacuum_ncaa_xmls)
        # Re-register cofactor GAFF templates onto the vacuum FF as well
        # so non-standard residues (GNP, ATP, …) receive parameters.
        if cofactor_mol2_paths:
            try:
                from run_restrained_md import register_cofactor_templates  # type: ignore
                register_cofactor_templates(vac_ff, cofactor_mol2_paths)
            except ImportError:
                pass
        try:
            vac_system = vac_ff.createSystem(
                modeller.topology,
                nonbondedMethod = app.NoCutoff,
                # NO `constraints=HBonds` — required for parmed compatibility.
            )
        except Exception as e:
            print(f"    [!] vacuum system 생성 실패 (binder={is_binder_side}): {e}")
            return None
        return vac_system

    cplx_vac_system = _build_vacuum(cplx_modeller, True)
    if cplx_vac_system is None:
        return None

    # --- 3. Subsystem topologies (position-transfer by atom key) ---
    def _atom_key(atom):
        res = atom.residue
        chain_id = res.chain.id if res.chain is not None else " "
        return (chain_id, res.name, str(res.id), atom.name)

    cplx_index_map = {_atom_key(a): a.index for a in cplx_modeller.topology.atoms()}

    def _load_subsystem(sub_pdb_path: str, sub_binder_chain: str):
        try:
            sub_pdb = PDBFile(sub_pdb_path)
        except Exception as e:
            print(f"    [!] subsystem PDB 로드 실패 ({sub_pdb_path}): {e}")
            return None
        sub_modeller = app.Modeller(sub_pdb.topology, sub_pdb.positions)
        if cofactor_mol2_paths:
            try:
                from run_restrained_md import inject_cofactor_bonds  # type: ignore
                inject_cofactor_bonds(sub_modeller, cofactor_mol2_paths)
            except ImportError:
                pass
        if sub_binder_chain:
            sub_modeller, _ = _apply_cyclic_bonds_mmgbsa(
                sub_modeller, sub_binder_chain,
            )
        else:
            sub_modeller.addHydrogens(ff)
        sub_vac = _build_vacuum(sub_modeller, bool(sub_binder_chain))
        if sub_vac is None:
            return None
        # Transfer minimized positions from complex → subsystem.
        sub_positions = list(sub_modeller.positions)
        for atom in sub_modeller.topology.atoms():
            key = _atom_key(atom)
            if key in cplx_index_map:
                sub_positions[atom.index] = cplx_min_positions[cplx_index_map[key]]
        return sub_modeller, sub_vac, sub_positions

    rec_triple = _load_subsystem(recv_pdb, sub_binder_chain="")
    lig_triple = _load_subsystem(lig_pdb, sub_binder_chain=binder_chain)
    if rec_triple is None or lig_triple is None:
        return None

    # --- 4. Export AMBER prmtop/inpcrd via parmed ---
    cplx_prefix = os.path.join(tmp_dir, "cplx")
    rec_prefix  = os.path.join(tmp_dir, "rec")
    lig_prefix  = os.path.join(tmp_dir, "lig")

    try:
        cplx_prm, cplx_inp, cplx_patched = _system_to_amber(
            cplx_modeller.topology, cplx_vac_system, cplx_min_positions, cplx_prefix,
        )
        rec_prm, rec_inp, rec_patched = _system_to_amber(
            rec_triple[0].topology, rec_triple[1], rec_triple[2], rec_prefix,
        )
        lig_prm, lig_inp, lig_patched = _system_to_amber(
            lig_triple[0].topology, lig_triple[1], lig_triple[2], lig_prefix,
        )
    except Exception as e:
        print(f"    [!] parmed prmtop 생성 실패: {e}")
        return None
    fallback_triggered = bool(cplx_patched or rec_patched or lig_patched)

    # --- 5. Build a 1-frame mdcrd from the minimized complex inpcrd ---
    # MMPBSA.py single-trajectory mode: -y complex.mdcrd. parmed rst7 is
    # accepted by MMPBSA.py as a 1-frame trajectory (the MDCRD reader
    # auto-detects format via extension or content).
    cplx_mdcrd = cplx_inp  # rst7 is a legitimate single-frame trajectory

    # --- 6. Run MMPBSA.py, parse result ---
    parsed = _run_mmpbsa_py(
        work_dir=tmp_dir,
        cplx_prmtop=cplx_prm, rec_prmtop=rec_prm, lig_prmtop=lig_prm,
        cplx_mdcrd=cplx_mdcrd, pbsa_cfg=pbsa_cfg, amberhome=amberhome,
    )
    if parsed is None:
        return None

    result = {
        "snapshot":              basename,
        "pdb_path":              pdb_path,
        "ncaa_element":          ncaa_elem,
        "si_radius_A":           si_radius,
        "delta_g_kcal":          parsed["delta_g_kcal"],
        "delta_epb_kcal":        parsed.get("delta_epb_kcal"),
        "delta_enpolar_kcal":    parsed.get("delta_enpolar_kcal"),
        "delta_edisper_kcal":    parsed.get("delta_edisper_kcal"),
        "favorable":             parsed["delta_g_kcal"] < 0,
        "protocol_variant":      "1traj",
        "solvent_model":         "pbsa",
        "minimize_iter":         _min_iter,
        "minimize_tol":          _min_tol,
        "platform":              platform.getName(),
        # ncAA fallback flags — R-11 audit trail. ``fallback_triggered``
        # flips to True when any of complex/receptor/ligand required the
        # bond-type patch in ``_system_to_amber``.
        "fallback_triggered":    fallback_triggered,
        "fallback_detail":       {
            "complex":  bool(cplx_patched),
            "receptor": bool(rec_patched),
            "ligand":   bool(lig_patched),
        },
    }

    out_json = os.path.join(output_dir, f"{basename}_mmpbsa.json")
    with open(out_json, "w", encoding="utf-8") as f:
        json.dump(result, f, indent=2)
    print(f"    ΔG_bind(PBSA) = {parsed['delta_g_kcal']:+.4f} kcal/mol")
    return result


