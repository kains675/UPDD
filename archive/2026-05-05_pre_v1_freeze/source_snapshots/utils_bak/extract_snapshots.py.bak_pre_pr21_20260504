# 단일 DCD 처리
# ==========================================
def process_trajectory(
    dcd_path, top_pdb, output_dir, n_snapshots, binder_chain="B",
    target_card=None,
):
    basename = os.path.basename(dcd_path).replace("_restrained.dcd", "").replace(".dcd", "")

    # ── [스마트 스킵 (도망자 검문소 2호)] ───────────────────────
    # 해당 디자인의 스냅샷 파일이 결과 폴더에 몇 개 있는지 확인합니다.
    existing_snaps = sorted(glob.glob(os.path.join(output_dir, f"{basename}_snap*.pdb")))

    if len(existing_snaps) >= n_snapshots:
        print(f"\n  [Skip] {basename} — 이미 목표 개수({n_snapshots}개)의 스냅샷이 존재합니다. 무거운 MDTraj 로딩을 생략합니다!")
        return existing_snaps[:n_snapshots]  # 이미 있는 파일 목록을 그대로 반환하여 파이프라인 지속
    # ────────────────────────────────────────────────────────

    print(f"\n  처리: {basename}")

    traj         = load_trajectory(dcd_path, top_pdb)
    # [R-17 G5] target_card 의 declared cofactor resnames 를 strip_solvent 에
    # 전달하여 GNP/Mg2+ 등 structural cofactor 가 snapshot 에 보존되도록 한다.
    _cofactor_resnames = []
    if target_card is not None:
        for _e in (target_card.get("cofactor_residues") or []):
            if isinstance(_e, dict) and _e.get("required") and _e.get("resname"):
                _cofactor_resnames.append(str(_e["resname"]).strip().upper())
    traj_protein = strip_solvent(traj, cofactor_resnames=_cofactor_resnames or None)

    # [R-17 G5] Snapshot 에 declared required cofactor 가 존재하는지 검증.
    # 부재 시 fail-fast 로 downstream QM/MM 진입 차단.
    if target_card is not None:
        validate_snapshot_cofactor_presence(
            traj_protein,
            target_card.get("cofactor_residues") or [],
            snapshot_label=basename,
        )

    selected     = cluster_and_select(traj_protein, n_snapshots, binder_chain=binder_chain)

    stats = calc_rmsd_stats(traj_protein, selected)
    if stats:
        print(f"  RMSD drift 평균 : {stats['rmsd_mean']:.3f} Å")
        print(f"  스냅샷 다양성   : {stats['snap_div_mean']:.3f} Å")

    saved = save_snapshots(traj_protein, selected, output_dir, basename)

    # RMSD 통계 저장
    if stats:
        log_path = os.path.join(output_dir, f"{basename}_rmsd_stats.txt")
        with open(log_path, "w", encoding="utf-8") as f:
            f.write(f"# {basename} RMSD 통계\n\n")
            f.write(f"전체 RMSD 평균   : {stats['rmsd_mean']:.3f} Å\n")
            f.write(f"전체 RMSD 최대   : {stats['rmsd_max']:.3f} Å\n")
            f.write(f"최종 프레임 RMSD : {stats['rmsd_final']:.3f} Å\n")
            f.write(f"스냅샷 다양성 평균: {stats['snap_div_mean']:.3f} Å\n")

    return saved

# ==========================================
# CLI 메인
# ==========================================
def main():
    parser = argparse.ArgumentParser(
        description="Snapshot Extraction — MDtraj K-Means 클러스터링"
    )
    parser.add_argument("--md_dir",      required=True,       help="MD 결과 디렉토리 (DCD + PDB)")
    parser.add_argument("--outputdir",   required=True,       help="스냅샷 출력 디렉토리")
    parser.add_argument("--n_snapshots", type=int, default=5, help="스냅샷 수 (기본 5)")
    # [v35 AUDIT] Principle 7: --binder_chain added to extend the v30 chain-aware
    # contract to the snapshot stage. Previously cluster_and_select hardcoded
    # `chainid 1`, silently selecting wrong CA atoms for any non-canonical
    # chain layout (e.g., multi-chain receptors).
    parser.add_argument("--binder_chain", default="B",         help="바인더 체인 문자 (기본 'B')")
    parser.add_argument(
        "--target_id", default="",
        help="[R-17 G5] target_card stem (예: 6WGN). 지정 시 "
             "cofactor_residues 가 strip_solvent 에서 보존되고 snapshot "
             "presence 가 검증된다.",
    )
    args = parser.parse_args()

    # [R-17 G5] target_card 로드 (optional). 실패 시 legacy 동작으로 fallback.
    target_card = None
    if args.target_id:
        try:
            from utils_common import load_target_card
            target_card = load_target_card(args.target_id)
            print(
                "  [R-17 G5] target_card '{}' 로드: cofactor_residues 보존 활성화".format(
                    args.target_id
                )
            )
        except Exception as _tc_err:
            print(
                "  [R-17 G5][WARN] target_card '{}' 로드 실패 ({}): legacy strip_solvent 사용".format(
                    args.target_id, _tc_err
                )
            )

    os.makedirs(args.outputdir, exist_ok=True)

    dcd_files = glob.glob(os.path.join(args.md_dir, "*_restrained.dcd"))
    if not dcd_files:
        dcd_files = glob.glob(os.path.join(args.md_dir, "*.dcd"))
    if not dcd_files:
        print(f"[!] DCD 파일 없음: {args.md_dir}")
        return

    print(f"\n[Snapshot Extraction]")
    print(f"  DCD 파일  : {len(dcd_files)}개")
    print(f"  스냅샷 수 : {args.n_snapshots}개/궤적")

    all_snapshots = []
    # [v0.5] JSON-based MD status with legacy fallback
    _md_status = load_md_status(os.path.dirname(args.md_dir))

    for dcd_path in dcd_files:
        base = dcd_path.replace("_restrained.dcd", "").replace(".dcd", "")
        design_stem = os.path.basename(base)

        # [v0.5 Bug 2 fix] JSON-aware explosion detection
        if _md_status and design_stem in _md_status.get("designs", {}):
            _entry = _md_status["designs"][design_stem]
            _action = _entry.get("extract_snapshots_action", "normal_trajectory")
            if _action == "skip":
                print(f"  [Skip] {design_stem} (tier={_entry.get('tier')}) "
                      f"— extract_snapshots_action=skip")
                continue
            is_exploded = (_action == "trim_exploded")
        else:
            # Legacy fallback (backward compat)
            exploded_logs = glob.glob(base + "_EXPLODED*.log")
            is_exploded = len(exploded_logs) > 0
            if is_exploded:
                print(f"  [Legacy fallback] {design_stem} "
                      f"— file-name heuristic (no _md_status.json)")

        # ── topology PDB 결정 (폭발 시 _final.pdb가 없을 수 있음) ──
        top_pdb = base + "_final.pdb"
        if not os.path.exists(top_pdb):
            candidate_pdbs = [p for p in glob.glob(base + "*.pdb")
                              if "_restrained" not in p and "_snap" not in p]
            if not candidate_pdbs:
                candidate_pdbs = glob.glob(os.path.join(args.md_dir, "*_final.pdb"))
            if not candidate_pdbs:
                candidate_pdbs = glob.glob(os.path.join(args.md_dir, "*.pdb"))
            if not candidate_pdbs:
                print(f"  [!] topology PDB 없음 — {os.path.basename(dcd_path)} 건너뜀")
                continue
            top_pdb = candidate_pdbs[0]
            print(f"  topology fallback: {os.path.basename(top_pdb)}")

        # ── [v56] 폭발 궤적: 유효 프레임 비율 판정 (20% AND 50프레임 이상) ──
        # 폭발 궤적: safety buffer 15%, 절대 최소 50프레임, 메타데이터 태깅.
        if is_exploded:
            try:
                traj_raw = md.load(dcd_path, top=top_pdb)
            except Exception as e:
                print(f"  [!] 💥 폭발 궤적 로드 실패: {e} — 건너뜀")
                continue

            total_frames = traj_raw.n_frames

            # NaN이 처음 등장하는 프레임 인덱스 탐색
            valid_count = total_frames
            for fi in range(total_frames):
                if np.any(np.isnan(traj_raw.xyz[fi])):
                    valid_count = fi
                    break

            # Safety buffer 15%: NaN 직전 구간 제거 (에너지 보존 검증 대체)
            valid_end = int(valid_count * 0.85)
            ratio = valid_end / total_frames if total_frames > 0 else 0

            if ratio < 0.2 or valid_end < 50:
                print(f"  [Pass] 💥 유효 프레임 {valid_end}/{total_frames} "
                      f"({ratio:.0%}, NaN@{valid_count}, buffer 15%) "
                      f"— 통계적으로 불충분하여 건너뜁니다.")
                continue

            print(f"  ⚠️  폭발 이력 있지만 유효 프레임 {valid_end}/{total_frames} "
                  f"({ratio:.0%}, NaN@{valid_count}, buffer 15%) — 유효 구간만 사용합니다.")

            # 유효 프레임만 잘라 임시 DCD로 저장 후 process_trajectory 호출
            traj_valid = traj_raw[:valid_end]
            trimmed_dcd = os.path.join(
                args.outputdir,
                os.path.basename(dcd_path).replace(".dcd", "_trimmed.dcd")
            )
            traj_valid.save_dcd(trimmed_dcd)
            try:
                snaps = process_trajectory(
                    trimmed_dcd, top_pdb, args.outputdir,
                    args.n_snapshots, binder_chain=args.binder_chain,
                    target_card=target_card,
                )
                all_snapshots.extend(snaps)

                # 메타데이터 태깅: truncated 궤적임을 기록
                basename = os.path.basename(dcd_path).replace("_restrained.dcd", "").replace(".dcd", "")
                meta_path = os.path.join(args.outputdir, f"{basename}_truncated_meta.txt")
                with open(meta_path, "w", encoding="utf-8") as _mf:
                    _mf.write(f"truncated=True\n")
                    _mf.write(f"original_frames={total_frames}\n")
                    _mf.write(f"nan_frame={valid_count}\n")
                    _mf.write(f"used_frames={valid_end}\n")
                    _mf.write(f"valid_ratio={ratio:.4f}\n")
                    _mf.write(f"safety_buffer=15%\n")
            except Exception as e:
                print(f"\n  [🚨 손상된 데이터 감지] {os.path.basename(dcd_path)}")
                print(f"  -> 사유: {e}")
                print(f"  -> 파일을 무시하고 다음으로 넘어갑니다!\n")
            finally:
                if os.path.exists(trimmed_dcd):
                    os.remove(trimmed_dcd)
            continue  # 폭발 처리 완료 → 다음 DCD

        # ── 정상 궤적 처리 (기존 로직 유지) ──
        try:
            snaps = process_trajectory(
                dcd_path, top_pdb, args.outputdir,
                args.n_snapshots, binder_chain=args.binder_chain,
                target_card=target_card,
            )
        except Exception as e:
            print(f"\n  [🚨 손상된 데이터 감지] {os.path.basename(dcd_path)}")
            print(f"  -> 사유: {e}")
            print(f"  -> 파일을 무시하고 다음으로 넘어갑니다!\n")
            continue
        all_snapshots.extend(snaps)

    # 전체 목록 저장
    manifest = os.path.join(args.outputdir, "snapshots_manifest.txt")
    with open(manifest, "w", encoding="utf-8") as f:
        f.write("# 추출된 스냅샷 목록\n")
        for s in all_snapshots:
            f.write(os.path.basename(s) + "\n")

    print(f"\n  총 {len(all_snapshots)}개 스냅샷 저장 완료")
    print(f"  출력 디렉토리: {args.outputdir}")
    print(f"  목록 파일    : {manifest}")


if __name__ == "__main__":
    main()
