def load_trajectory(dcd_path, top_pdb):
    """DCD + topology PDB → MDtraj Trajectory"""
    print(f"  궤적 로드: {os.path.basename(dcd_path)}")
    traj = md.load(dcd_path, top=top_pdb)
    print(f"  프레임 수: {traj.n_frames}")
    print(f"  원자 수  : {traj.n_atoms}")
    return traj


# ==========================================
# [R-17 G5] 용매 제거 — declared cofactor 보존
# ==========================================
# SciVal 8차 verdict (verdict_cofactor_preservation_policy_20260419.md §2.3 G5).
# 기존 구현은 ``resname MG/CA/ZN`` 을 하드코딩하여 제거했으나, target_card 에
# ``cofactor_residues`` 로 선언된 MG/ZN 은 structural cofactor 이며 제거 금지.
# 7차 verdict 의 Stage C root cause — MD snapshot 에서 GNP/Mg2+ 가 누락된
# 1차 원인이 이 하드코딩된 제거였음.
_SOLVENT_RESNAMES_DEFAULT = {"NA", "CL", "K", "CA", "MG", "ZN"}


def strip_solvent(traj, cofactor_resnames=None):
    """[R-17 G5] 물·이온 제거 → 단백질·펩타이드·ncAA + 선언된 cofactor 유지.

    기존 시그니처 ``strip_solvent(traj)`` 와 완전 호환. 새 두 번째 파라미터
    ``cofactor_resnames`` 가 제공되면 제거 대상 resname 집합에서 해당
    resnames 를 제외한다 (즉 cofactor 는 원자 slice 후에도 남는다).

    Args:
        traj: mdtraj.Trajectory.
        cofactor_resnames: Optional iterable of resnames to preserve
            (case-insensitive, upper-cased internally). Commonly passed
            from ``target_card.cofactor_residues[*].resname`` where
            ``required=True``. When ``None`` (legacy callers), falls back
            to the pre-R17 hardcoded set.

    Returns:
        mdtraj.Trajectory with solvent / counter-ion residues sliced out but
        declared cofactor resnames retained.
    """
    preserve = set()
    if cofactor_resnames:
        preserve = {str(r).strip().upper() for r in cofactor_resnames if r}

    # Remove-list = default solvent/ion names MINUS declared cofactors.
    removable = _SOLVENT_RESNAMES_DEFAULT - preserve

    selection_terms = ["not water"]
    for rn in sorted(removable):
        selection_terms.append(f"not resname {rn}")
    selection = " and ".join(selection_terms)

    protein_idx = traj.topology.select(selection)
    traj_stripped = traj.atom_slice(protein_idx)
    if preserve:
        print(
            f"  [R-17 G5] cofactor preserved through strip_solvent: "
            f"{sorted(preserve)} | remove-list: {sorted(removable)}"
        )
    print(f"  용매 제거 후 원자 수: {traj_stripped.n_atoms}")
    return traj_stripped


def validate_snapshot_cofactor_presence(traj, cofactor_entries, snapshot_label=""):
    """[R-17 G5] Verify that every ``required=True`` cofactor survived into snapshot.

    Args:
        traj: mdtraj.Trajectory — after ``strip_solvent`` and any downstream
            slicing. ``traj.topology`` is inspected for residue resnames.
        cofactor_entries: List of dicts (``target_card.cofactor_residues``).
            Only entries with ``required=True`` are checked.
        snapshot_label: Optional human-readable snapshot identifier for error
            messages (e.g. ``"snap01"``). Default empty string.

    Raises:
        CofactorMissingError: A required cofactor resname is absent from
            ``traj.topology.residues``.
    """
    if not cofactor_entries:
        return
    required = [
        str(e.get("resname", "")).strip().upper()
        for e in cofactor_entries
        if isinstance(e, dict) and e.get("required") and e.get("resname")
    ]
    if not required:
        return

    present = {res.name.strip().upper() for res in traj.topology.residues}
    missing = [rn for rn in required if rn not in present]
    if missing:
        raise CofactorMissingError(
            "R-17 G5 snapshot: required cofactor resnames {} absent from "
            "snapshot{}. Present resnames sample: {}. This indicates the MD "
            "force field dropped them (G4 bug) or strip_solvent was called "
            "without cofactor_resnames argument (G5 regression).".format(
                missing,
                f" '{snapshot_label}'" if snapshot_label else "",
                sorted(present)[:20],
            ),
            gate="G5",
            resname=missing[0],
            detail={"missing": missing, "snapshot": snapshot_label},
        )


# ==========================================
# [v35 AUDIT] Principle 7: Binder chain resolver
# ==========================================
# Prior to this audit, cluster_and_select hardcoded `chainid 1` as the binder,
# silently selecting the wrong residues whenever the topology placed the binder
# in any position other than the second chain (e.g., multi-chain receptors).
# The orchestrator UPDD.py now passes --binder_chain as part of the v30 contract,
# so this helper resolves a chain *letter* (A/B/C...) to the mdtraj *chainid*
# integer at call time, falling back to legacy behavior only when resolution
# fails (so pre-existing batch runs still complete).
def _resolve_binder_chainid(topology, binder_chain_letter):
    """[Backwards-Compat Wrapper] utils_common.resolve_chainid_by_letter 위임.

    기존 호출부와의 시그니처 호환을 위해 wrapper로 유지한다.
    """
    return _resolve_chainid_common(topology, binder_chain_letter)


# ==========================================
# RMSD 기반 클러스터링으로 대표 스냅샷 선택
# ==========================================
def cluster_and_select(traj, n_snapshots, binder_chain="B"):
    """
    1. CA 원자 좌표 행렬 추출
    2. StandardScaler 정규화
    3. K-Means 클러스터링
    4. 각 클러스터 중심에 가장 가까운 프레임 선택
    """
    n_frames = traj.n_frames

    if n_frames <= n_snapshots:
        print(f"  프레임({n_frames}) <= 요청({n_snapshots}) — 전체 프레임 사용")
        return list(range(n_frames))

    # [v35 AUDIT] Principle 7: resolve the binder chain letter (from CLI) to the
    # actual mdtraj chainid at runtime. If the topology's chain IDs are blank
    # (some PDB writers emit ' ' for chain column), fall through to the legacy
    # chainid 1 heuristic, then to an any-CA fallback. NONE of the historical
    # fallback paths are removed — only preceded by a more precise lookup.
    resolved_chainid = _resolve_binder_chainid(traj.topology, binder_chain)
    ca_idx = np.array([], dtype=int)
    if resolved_chainid is not None:
        ca_idx = traj.topology.select(f"name CA and chainid {resolved_chainid}")
        if len(ca_idx) > 0:
            print(f"  바인더 체인 해석: '{binder_chain}' → chainid {resolved_chainid} (CA 원자 {len(ca_idx)}개)")
    if len(ca_idx) == 0:
        # [Fallback Warning] 명시적 chain 해석 실패 시 chainid=1(legacy heuristic)으로 폴백한다.
        # 이 경로는 다중 체인 receptor 구조에서 잘못된 잔기를 선택할 수 있으므로
        # 운영자에게 명시적으로 알린다 (Principle 4: 데이터 신뢰도).
        print(f"  [!] 바인더 체인 '{binder_chain}' 해석 실패 — legacy chainid=1 폴백 적용 (수동 검증 권장)")
        ca_idx = traj.topology.select("name CA and chainid 1")
    if len(ca_idx) == 0:
        print("  [!] chainid=1 폴백도 실패 — name CA 전체 폴백 적용 (구조 비선형성 의심)")
        ca_idx = traj.topology.select("name CA")
    if len(ca_idx) == 0:
        print("  [!] CA 원자 없음 — 균등 간격으로 선택")
        step = n_frames // n_snapshots
        return [i * step for i in range(n_snapshots)]

    print(f"  클러스터링 기준 CA 원자: {len(ca_idx)}개")

    # 첫 프레임 기준 슈퍼포지션
    traj_ca = traj.atom_slice(ca_idx)
    traj_ca.superpose(traj_ca, 0)

    # 좌표 행렬 → K-Means
    coords        = traj_ca.xyz.reshape(n_frames, -1)
    coords_scaled = StandardScaler().fit_transform(coords)

    print(f"  K-Means 클러스터링 (k={n_snapshots})...")
    actual_k = min(n_snapshots, n_frames)
    kmeans = KMeans(n_clusters=actual_k, random_state=42, n_init=10)
    labels = kmeans.fit_predict(coords_scaled)

    # 각 클러스터에서 중심에 가장 가까운 프레임 선택
    selected = []
    for cid in range(actual_k):
        members = np.where(labels == cid)[0]
        if len(members) == 0:
            continue
        center = kmeans.cluster_centers_[cid]
        dists  = np.linalg.norm(coords_scaled[members] - center, axis=1)
        selected.append(int(members[np.argmin(dists)]))

    selected = sorted(selected)
    print(f"  선택 프레임: {selected}")
    return selected


# ==========================================
# RMSD 통계
# ==========================================
def calc_rmsd_stats(traj, selected_frames) -> dict:
    """전체 궤적 및 선택된 스냅샷 군집의 RMSD 통계를 계산한다.

    Returns:
        dict: 다음 5개 float 키를 담은 딕셔너리.
            - rmsd_mean      : 첫 프레임 기준 전체 궤적 RMSD 평균 (Å)
            - rmsd_max       : 첫 프레임 기준 전체 궤적 RMSD 최대 (Å)
            - rmsd_final     : 마지막 프레임의 첫 프레임 기준 RMSD (Å)
            - snap_div_mean  : 선택된 스냅샷 간 pairwise RMSD 평균 (Å)
            - snap_div_max   : 선택된 스냅샷 간 pairwise RMSD 최대 (Å)
        CA 원자가 0개인 비정상 궤적의 경우 빈 딕셔너리({})를 반환한다.
    """
    ca_idx = traj.topology.select("name CA")
    if len(ca_idx) == 0:
        return {}

    traj_ca  = traj.atom_slice(ca_idx)
    rmsd_all = md.rmsd(traj_ca, traj_ca, 0) * 10  # nm → Å

    snap_traj = traj_ca.slice(selected_frames)
    n         = len(selected_frames)
    pairwise  = np.zeros((n, n))
    for i in range(n):
        pairwise[i] = md.rmsd(snap_traj, snap_traj, i) * 10

    iu = np.triu_indices(n, k=1)
    return {
        "rmsd_mean":     float(np.mean(rmsd_all)),
        "rmsd_max":      float(np.max(rmsd_all)),
        "rmsd_final":    float(rmsd_all[-1]),
        "snap_div_mean": float(np.mean(pairwise[iu])) if len(iu[0]) > 0 else 0.0,
        "snap_div_max":  float(np.max(pairwise)),
    }


# ==========================================
# 스냅샷 PDB 저장
# ==========================================
def _unwrap_binder_manual(frame, binder_chain_idx=None):
    """Minimum-image convention으로 바인더를 타겟 근처로 이동.

    image_molecules()와 달리 bond graph가 필요 없고,
    multi-chain complex에서 올바르게 작동한다.

    원리: 바인더 centroid와 타겟 centroid의 차이가 box/2를 초과하면
    box 크기만큼 shift하여 최근접 이미지로 이동.
    """
    if frame.unitcell_lengths is None:
        print("    [PBC] unitcell 정보 없음 — unwrap 건너뜀")
        return

    box = frame.unitcell_lengths[0]  # [Lx, Ly, Lz] in nm
    top = frame.topology
    chains = list(top.chains)

    if len(chains) < 2:
        return

    # 바인더 chain 자동 탐색: 잔기 수가 가장 적은 chain을 바인더로 간주
    if binder_chain_idx is None:
        target_chain_idx = max(range(len(chains)), key=lambda i: chains[i].n_residues)
        binder_chain_idx = min(range(len(chains)), key=lambda i: chains[i].n_residues)
        # 타겟(가장 큰 chain)과 같으면 두 번째로 작은 chain 선택
        if binder_chain_idx == target_chain_idx and len(chains) > 1:
            binder_chain_idx = 1 if target_chain_idx != 1 else 0
    else:
        target_chain_idx = 0

    target_atoms = [a.index for a in chains[target_chain_idx].atoms]
    binder_atoms = [a.index for a in chains[binder_chain_idx].atoms]

    if not target_atoms or not binder_atoms:
        return

    target_center = np.mean(frame.xyz[0, target_atoms], axis=0)
    binder_center = np.mean(frame.xyz[0, binder_atoms], axis=0)

    diff = binder_center - target_center
    shift = np.zeros(3)
    for dim in range(3):
        while diff[dim] + shift[dim] > box[dim] / 2:
            shift[dim] -= box[dim]
        while diff[dim] + shift[dim] < -box[dim] / 2:
            shift[dim] += box[dim]

    if np.any(shift != 0):
        frame.xyz[0, binder_atoms] += shift
        dist_before = np.linalg.norm(diff)
        dist_after = np.linalg.norm(diff + shift)
        print(f"    [PBC Fix] 바인더 이동: {shift*10} Å "
              f"(거리: {dist_before*10:.1f}->{dist_after*10:.1f} Å)")
    else:
        print(f"    [PBC] 바인더 위치 정상 (이동 불필요)")


def _unwrap_frame_pbc(frame):
    """[v39 FIX — Bug 1] 단일 프레임 trajectory 의 PBC 를 unwrap 한다.

    DCD 궤적은 주기적 경계 조건에 의해 각 분자가 독립적으로 래핑되어 있을 수
    있다. save_pdb 는 래핑된 좌표를 그대로 직렬화하므로, 타겟-바인더가 이웃
    이미지 셀에 나뉘어 저장되면 하류 QM/MM 의 "도망자 발견" 필터
    (min_dist > 8 Å) 가 매번 발동하여 early-return 한다 (run_qmmm.py:420).

    전략:
        1. unitcell 정보가 없으면 no-op (비주기 시스템).
        2. find_molecules() 로 bond graph 기반 분자 분해를 수행하고 가장 큰
           분자를 명시적 anchor 로 지정하여 image_molecules 를 호출한다.
           mdtraj 의 기본 guess_anchor_molecules() 는 anchor 크기가 전체의
           절반을 초과해야 하는데, 대형 단백질-펩타이드 복합체에서는 타겟이
           85-95% 수준이라 heuristic 이 실패하는 경우가 있다. 명시적 anchor
           지정으로 이 제한을 우회한다.
        3. image_molecules 가 실패하면 make_molecules_whole 로 폴백.
        4. 최후 수단으로 원본 좌표 유지 (경고 출력).

    GROMACS `trjconv -pbc mol -center` 에 해당하는 처리이다. 과학적 근거:
    implicit solvent/진공 계산에서 원자 간 거리는 물리적으로 무의미한
    래핑 좌표가 아니라 실제 화학적 거리여야 한다.
    """
    if frame.unitcell_vectors is None:
        return frame
    try:
        mols = frame.topology.find_molecules()
        if mols:
            anchor = max(mols, key=len)
            frame.image_molecules(inplace=True, anchor_molecules=[anchor])
            # [v52] image_molecules 후에도 잔여 래핑이 있을 수 있으므로 보조 수정
            _unwrap_binder_manual(frame)
            return frame
    except Exception as _img_err:
        try:
            frame.make_molecules_whole(inplace=True)
            return frame
        except Exception as _whole_err:
            # [v52 FIX] 수동 minimum-image fallback
            try:
                _unwrap_binder_manual(frame)
            except Exception as _manual_err:
                print(f"  [!] PBC unwrap 실패: "
                      f"image_molecules={_img_err.__class__.__name__}, "
                      f"make_molecules_whole={_whole_err.__class__.__name__}, "
                      f"manual={_manual_err.__class__.__name__} "
                      f"— 래핑된 좌표로 저장 (하류 QM/MM 에서 '도망자 발견' 가능)")
    return frame


def _ensure_intrachain_peptide_bonds(traj):
    """[v54 helper] 동일 chain 의 인접 두 residue 사이 C-N 펩타이드 결합이
    topology 에 없는 경우 추가한다.

    Background — strip_solvent / mdtraj.load 는 ncAA (예: MTR) 의 HETATM
    tag 잔기와 인접 canonical (ATOM tag) 잔기 사이의 peptide bond 를
    bond graph 에 등록하지 않는 경우가 많다. 이 결과 `find_molecules()`
    가 MTR 의 backbone N (또는 인접 residue 의 C) 을 single-atom
    "molecule" 로 분류하고, `image_molecules` 가 그 atom 을 anchor
    molecule 과 독립적으로 imaging 하여 within-chain peptide bond 가
    PBC 를 가로질러 복원되지 않거나 오히려 boundary 로 끌려가는 경우가
    발생한다 (Phase β Stage 1-Repair 진단의 v53 회귀 메커니즘).

    이 helper 는 보수적으로 다음 조건의 누락 결합만 추가한다:
        - 동일 chain
        - 잔기 인덱스 가 1 차이 (직접 인접)
        - 두 잔기 모두 backbone C / N atom 을 가짐
        - 이미 결합이 등록되어 있지 않음
        - 두 atom 의 평균 좌표 거리가 box 의 반보다 작거나, box 가 없음

    좌표 거리 조건이 없으면 PBC-broken frame 에서 "잘못된" 결합 (실제로
    boundary 너머의 atom 과의 결합) 을 만들 수 있으므로, 좌표 검사 후
    box/2 미만일 때만 결합을 등록한다 (즉 within-cell distance 가 합리
    적인 경우만). 만약 boundary 를 가로지르는 frame 이라면 결합은
    추가하지 않고 후속 processing 으로 위임한다.

    Returns:
        int: 추가된 결합 수.
    """
    top = traj.topology
    existing = set()
    for b in top.bonds:
        existing.add(frozenset((b.atom1.index, b.atom2.index)))

    added = 0
    # box (nm) — first frame's unitcell, only used as a sanity check.
    box = None
    if traj.unitcell_lengths is not None and traj.n_frames > 0:
        box = traj.unitcell_lengths[0]

    chains = list(top.chains)
    for ch in chains:
        residues = list(ch.residues)
        for i in range(len(residues) - 1):
            r_curr = residues[i]
            r_next = residues[i + 1]
            # Backbone C of current, N of next.
            c_atom = next((a for a in r_curr.atoms if a.name == "C"), None)
            n_atom = next((a for a in r_next.atoms if a.name == "N"), None)
            if c_atom is None or n_atom is None:
                continue
            key = frozenset((c_atom.index, n_atom.index))
            if key in existing:
                continue
            # Sanity: in some frame (use first), is this distance reasonable?
            # If they are far apart in EVERY frame, it isn't really a peptide
            # bond. We accept the bond if at least one frame has the atoms
            # within ~3 Å (typical peptide bond ~1.33 Å + margin), accounting
            # for periodic-boundary wrap by checking minimum-image distance.
            try:
                xyz_c = traj.xyz[:, c_atom.index, :]
                xyz_n = traj.xyz[:, n_atom.index, :]
                diff = xyz_n - xyz_c  # (n_frames, 3)
                if box is not None:
                    diff = diff - np.round(diff / box) * box
                d_nm = np.linalg.norm(diff, axis=1)
                if np.min(d_nm) > 0.30:  # 3 Å — too far for any frame
                    continue
            except Exception:
                continue
            top.add_bond(c_atom, n_atom)
            existing.add(key)
            added += 1
    return added


def save_snapshots(traj, selected_frames, output_dir, basename):
    """스냅샷 PDB 를 저장한다.

    [v54 FIX — L387 PBC defect, 2026-04-29] mdtraj 의 PDB-format
    topology loader 는 ncAA HETATM 잔기와 인접 canonical ATOM 잔기
    사이의 peptide 결합을 bond graph 에 등록하지 않는 경우가 있다
    (HETATM/ATOM tag 경계). 결과적으로 `find_molecules()` 는 ncAA 의
    backbone atom 을 독립 "molecule" 로 분류하고, 후속 `image_molecules`
    가 boundary 를 가로지르는 frame 에서 within-chain peptide bond 를
    잘못 imaging 하여 ~113 Å broken bond 를 PDB 에 직렬화한다 (Phase β
    Stage 1-Repair 진단의 smoking gun).

    [v54 patch] 두 단계 layered approach:
        Layer 0 (NEW): `_ensure_intrachain_peptide_bonds(traj)` — 동일
            chain 의 인접 잔기 C-N 결합이 누락된 경우 conservatively
            추가하여 `find_molecules()` 가 chain 전체를 단일 분자로
            인식하도록 한다.
        Layer 1: `_unwrap_frame_pbc(frame)` — image_molecules(anchor=
            largest molecule, make_whole=True). Layer 0 덕분에 이제
            chain 전체가 anchor 와 함께 imaging 되어 within-chain
            peptide bond 가 정상 거리 (~1.3 Å) 로 복원된다.
        Layer 2: `_unwrap_binder_manual(frame)` — receptor↔binder
            centroid minimum-image. multi-chain complex 의 inter-chain
            상대 위치 보정용 (image_molecules 만으로는 두 chain
            centroid 의 inter-chain distance > box/2 case 가 처리되지
            않는다).

    Pre-v54 (v53) 동작: Layer 1 이 빠진 채 Layer 2 만 호출했으나, Layer
    2 는 chain 전체 centroid 만 shift 하므로 within-chain broken bond 는
    복원하지 못함. v53 회귀 결과 7TL8_MTR6_s7 median 112.64 Å (broken)
    PDB 가 production 으로 흘러갔다.

    [v39 FIX — Bug 1] save_pdb 직전에 PBC 래핑을 해제한다.

    Reference:
        outputs/analysis/phase_beta_stage1_repair_20260428.md
            §3.3 (smoking gun — 7TL8_MTR6_s7 median 112.64 Å)
            §3.4 (HETATM/ATOM tag mismatch mechanism)
            §4.2 (patch design)
        Verification: scripts/verify_pbc_integrity.py
    """
    # [v54 Layer 0] Repair missing inter-residue peptide bonds in the
    # topology so image_molecules sees chains as single molecules. This
    # is a one-time topology mutation per save_snapshots invocation.
    n_added = _ensure_intrachain_peptide_bonds(traj)
    if n_added > 0:
        print(f"  [v54] 누락된 chain-internal peptide bond {n_added}개 추가 (image_molecules anchor 정확도 확보)")

    saved = []
    for i, fidx in enumerate(selected_frames):
        frame = traj.slice([fidx])

        # [v54 Layer 1] image_molecules(anchor=largest molecule,
        # make_whole=True) — within-chain peptide bonds 가 boundary 에
        # 걸친 경우 정상 거리(~1.3 Å)로 복원. Layer 0 가 chain 결합을
        # 보강했으므로 ncAA HETATM/ATOM tag 경계에서도 동작.
        _unwrap_frame_pbc(frame)

        # [v54 Layer 2 — v53 retained] receptor↔binder centroid minimum-
        # image 보정. multi-chain complex 의 inter-chain 상대 위치 처리용.
        _unwrap_binder_manual(frame)

        out_pdb = os.path.join(
            output_dir,
            f"{basename}_snap{i+1:02d}_f{fidx}.pdb"
        )
        frame.save_pdb(out_pdb)
        # [v0.6.7] Inject ncAA CONECT so MM-GBSA can template-match the
        # mutated residue + its flanking peptide bonds. mdtraj's save_pdb
        # does not emit CONECT for non-standard residues, so we post-patch.
        _inject_ncaa_conect(out_pdb)
        saved.append(out_pdb)
        print(f"  스냅샷 {i+1:2d}: 프레임 {fidx:5d} → {os.path.basename(out_pdb)}")
    return saved


def _format_pdb_serial_v55(idx_1based: int) -> str:
    """[v55] Format a 1-based atom index as a 5-character PDB serial field.

    Decimal for 1..99999; hex-extended (PDB v4 informal extension; OpenMM
    PDB parser supports it via ``int(s, 16) - 0xA0000 + 100000``) for
    100000..493215. Above that range raises ValueError (out of 5-col field
    capacity).
    """
    if idx_1based < 1:
        raise ValueError(f"atom index must be ≥ 1, got {idx_1based}")
    if idx_1based <= 99999:
        return f"{idx_1based:5d}"
    # Hex-extended: 100000 maps to "A0000" (= 0xA0000 = 655360 → 655360 - 0xA0000 + 100000 = 100000)
    hex_val = (idx_1based - 100000) + 0xA0000
    if hex_val > 0xFFFFF:
        raise ValueError(
            f"atom index {idx_1based} exceeds hex-extended PDB serial capacity (max 493215)"
        )
    return f"{hex_val:05X}"


def _inject_ncaa_conect(pdb_path):
    """Scan the PDB for ncAA residues (non-standard names present in registry)
    and emit CONECT records for their internal bonds + flanking peptide bonds.

    Required because mdtraj.save_pdb omits CONECT for non-standard residues,
    and downstream MM-GBSA + ForceField template matching cannot infer bonds
    at the ncAA boundary (the surrounding standard residues fail "bonds
    different" if the external peptide bond is missing).

    [v55 FIX 2026-04-29 — CONECT wraparound]
        Two-part fix for PDB 5-digit serial column wraparound at >99,999 atoms:

        Part A (residue map disambiguation): the legacy code keyed
        ``by_serial[serial] → (chain, resnum, resname)`` which collided when
        wrapped water atoms (post-99999 → 0,1,2,...) overwrote ncAA atom
        entries. The v55 code uses ``(chain, resnum) → resname`` directly
        (no serial intermediate) and stores file-position ``atom_index`` as
        the unique disambiguator inside ``residues[(chain, resnum)]``. This
        bypasses serial collisions entirely.

        Part B (PDB-wide unique serials): OpenMM's PDBFile reader builds
        ``atomByNumber[serial] = atom`` to resolve CONECT references; with
        wrapped serials the reader collapses many atoms to the same key
        (last-write-wins) so CONECT records pointing at MTR atoms instead
        resolved to wrapped water atoms. v55 therefore RE-SERIALIZES all
        ATOM/HETATM lines with unique hex-extended serials (1..99999 stay
        decimal, 100000+ become "A0000"-style hex per the PDB v4 extended
        convention OpenMM supports natively in ``_parse_atom_index``).
        Existing CONECT records are remapped to the new serials; new
        CONECT records emitted here use the new serials directly. TER
        records' serial fields are also remapped to keep field consistency.

        Pre-v55 failure mechanism (Phase β #84): at >99,999 atoms, mdtraj
        save_pdb wraps the serial counter back to 0. Old ``by_serial`` dict
        overwrote MTR atom entries with HOH atoms; iteration then looked up
        the residue resname via ``by_serial[any_serial][2]`` → "HOH", so the
        ncAA registry lookup ``pdb_to_def.get("HOH")`` returned None and the
        residue was skipped → 0 CONECT records → OpenMM ForceField raised
        "No template found for residue ... (MTR). The set of atoms matches
        MTR, but the residue has no bonds between its atoms."

        Affected systems (Phase β #84): 2QKI_Cp4 × 8 (~123k atoms),
        7TL8_MTR6_s19 / s42 (~144k atoms each).

        Reference: outputs/analysis/phase_beta_mmpbsa_rerun_20260429.md §5.2.
    """
    try:
        import sys as _sys
        if os.path.dirname(__file__) not in _sys.path:
            _sys.path.insert(0, os.path.dirname(__file__))
        from ncaa_registry import NCAA_REGISTRY_DATA  # lazy import
        from parent_topology import parent_heavy_bonds, parent_h_name_table, _load_parent_template
    except Exception:
        return  # registry unavailable — skip injection

    # Build PDB resname → ncaa_def index for quick lookup
    pdb_to_def = {d.pdb_resname: d for d in NCAA_REGISTRY_DATA}

    def _allowed_atoms_for(ncaa_def) -> set:
        """Return the set of atom names valid for this ncAA's internal-form
        template: parent heavy + parent H names + extension heavy + extension H
        names. Any atom in a snap PDB not in this set is a leftover from pre-fix
        MTR H9 / HX1 spurious hydrogen and should be stripped.
        """
        parent = getattr(ncaa_def, "parent_residue", None)
        if not parent:
            return set()
        tmpl = _load_parent_template(parent)
        allowed = set()
        if tmpl is not None:
            atoms_in_parent, _bonds = tmpl
            allowed.update(atoms_in_parent.keys())
        # Extension atoms + their H's
        for (ext_name, ext_elem, _attach, _bl) in (getattr(ncaa_def, "extension_atoms", ()) or ()):
            if not ext_name:
                continue
            allowed.add(ext_name)
            if ext_elem in ("F", "Cl", "Br", "I"):
                continue
            suffix = ext_name[1:]
            if not suffix:
                continue
            if len(suffix) == 1:
                allowed.update(f"H{suffix}{i+1}" for i in range(3))
            else:
                allowed.update((f"H{suffix}", f"H{suffix}b", f"H{suffix}c"))
        return allowed

    # Read file, locate ncAA residues
    with open(pdb_path, "r", encoding="utf-8") as f:
        lines = f.readlines()

    # Strip out atoms not allowed by each ncAA residue's template (e.g. H9 / HX1
    # left over from pre-fix MTR XML). Must happen BEFORE CONECT building so
    # the residue atom map below reflects the clean set.
    atoms_to_keep = []
    for line in lines:
        if not line.startswith(("ATOM", "HETATM")):
            atoms_to_keep.append(line)
            continue
        if len(line) < 54:
            atoms_to_keep.append(line)
            continue
        resname = line[17:20].strip()
        d = pdb_to_def.get(resname)
        if d is None or not getattr(d, "parent_residue", None):
            atoms_to_keep.append(line)
            continue
        allowed = _allowed_atoms_for(d)
        atom_name = line[12:16].strip()
        if atom_name in allowed:
            atoms_to_keep.append(line)
        # Else drop the spurious atom (do not append)
    lines = atoms_to_keep

    # [v55 Part A] Atom-index based residue map. The atom_index is the running
    # counter of ATOM/HETATM records in `lines` (post-strip). It is unique by
    # construction and immune to PDB-serial 5-digit wraparound — a wrapped
    # water atom shares its serial with an MTR atom but never its file
    # position, so atom_map collisions are eliminated.
    #
    # We also detect whether ANY atom would need re-serialization (i.e. total
    # atom count > 99999 OR any duplicate serials present in the source). If
    # so, we re-serialize the entire file (Part B) using hex-extended PDB
    # serials (decimal 1..99999, then "A0000".."FFFFF") so OpenMM's PDBFile
    # `atomByNumber[serial]` map is collision-free and CONECT records can be
    # uniquely resolved to atoms.
    residues = {}
    resname_by_key = {}
    atom_index_to_lineno = {}      # atom_index → index in `lines`
    old_serial_to_indices = {}     # raw 5-char serial string → list of atom_indices
    atom_index = 0
    for lineno, line in enumerate(lines):
        if not line.startswith(("ATOM", "HETATM")) or len(line) < 54:
            continue
        try:
            resnum = int(line[22:26].strip())
        except (ValueError, IndexError):
            continue
        name = line[12:16].strip()
        chain = line[21]
        resname = line[17:20].strip()
        serial_str = line[6:11].strip()

        residues.setdefault((chain, resnum), {})[name] = atom_index
        resname_by_key.setdefault((chain, resnum), resname)
        atom_index_to_lineno[atom_index] = lineno
        old_serial_to_indices.setdefault(serial_str, []).append(atom_index)
        atom_index += 1

    n_atoms = atom_index
    needs_reserialize = (n_atoms > 99999) or any(
        len(v) > 1 for v in old_serial_to_indices.values()
    )

    # [v55 Part B] Build atom_index → new_serial_string mapping.
    # If no re-serialization needed, use the raw source serial.
    new_serial = {}
    if needs_reserialize:
        for ai in range(n_atoms):
            new_serial[ai] = _format_pdb_serial_v55(ai + 1)  # 1-based
    else:
        for ai in range(n_atoms):
            ln = atom_index_to_lineno[ai]
            new_serial[ai] = lines[ln][6:11].strip()

    # Build old serial → atom_index mapping (used to remap pre-existing CONECT).
    # When duplicates exist (wraparound), prefer the FIRST occurrence (which
    # was the canonical decimal-numbered atom; later collisions are wrap
    # artefacts whose original "intent" can't be inferred — but pre-existing
    # CONECT records were authored by mdtraj before wrap occurred for the
    # canonical atoms, so first-occurrence is the safe choice).
    old_serial_first_index = {s: idxs[0] for s, idxs in old_serial_to_indices.items()}

    # Collect already-emitted CONECT pairs (keyed by atom_index, so the dedupe
    # is collision-free even when raw serials clashed). Bonds that referenced
    # a wrap-collided serial may resolve to the wrong atom here — but those
    # were broken in the source anyway, so no regression.
    existing_pairs = set()
    for line in lines:
        if line.startswith("CONECT"):
            parts = line[6:].split()
            if not parts:
                continue
            base_idx = old_serial_first_index.get(parts[0])
            if base_idx is None:
                continue
            for other in parts[1:]:
                other_idx = old_serial_first_index.get(other)
                if other_idx is None:
                    continue
                existing_pairs.add(frozenset((base_idx, other_idx)))

    new_conect_pairs = []  # list of (idx1, idx2) — emitted in collection order

    def _add(idx1, idx2):
        if idx1 is None or idx2 is None or idx1 == idx2:
            return
        key = frozenset((idx1, idx2))
        if key in existing_pairs:
            return
        existing_pairs.add(key)
        new_conect_pairs.append((idx1, idx2))

    # For each residue, look up resname directly via (chain, resnum) key
    # (no by_serial intermediate → no wraparound collision). Emit the same
    # set of bonds the pre-v55 code emitted.
    for key, atom_map in residues.items():
        chain, resnum = key
        resname = resname_by_key.get(key, "")
        d = pdb_to_def.get(resname)
        if d is None or not getattr(d, "parent_residue", None):
            continue
        # Parent residue heavy bonds (e.g., TRP canonical bonds for MTR)
        for a1, a2 in parent_heavy_bonds(d.parent_residue):
            _add(atom_map.get(a1), atom_map.get(a2))
        # Extension atom bonds (e.g., NE1-CM for MTR)
        for (ext_name, _e, attach, _bl) in (getattr(d, "extension_atoms", ()) or ()):
            _add(atom_map.get(attach), atom_map.get(ext_name))
        # H-to-heavy bonds from amber14 parent template (HB2 on CB, HD1 on
        # CD1, etc.) — non-standard residues need CONECT for H's too.
        for heavy_name, h_names in parent_h_name_table(d.parent_residue).items():
            for h_name in h_names:
                _add(atom_map.get(heavy_name), atom_map.get(h_name))
        # Extension H names (HM1/HM2/HM3 on CM, H1P on O1P, etc.)
        for (ext_name, _e, _attach, _bl) in (getattr(d, "extension_atoms", ()) or ()):
            if not ext_name:
                continue
            suffix = ext_name[1:]  # e.g., "M" for CM, "1P" for O1P
            if not suffix:
                continue
            candidates = ([f"H{suffix}{i+1}" for i in range(3)]
                          if len(suffix) == 1 else
                          [f"H{suffix}", f"H{suffix}b", f"H{suffix}c"])
            for h in candidates:
                if h in atom_map:
                    _add(atom_map.get(ext_name), atom_map.get(h))
        # External peptide bonds (prev_C→N and C→next_N)
        prev_map = residues.get((chain, resnum - 1), {})
        next_map = residues.get((chain, resnum + 1), {})
        _add(prev_map.get("C"), atom_map.get("N"))
        _add(atom_map.get("C"), next_map.get("N"))

    # If nothing to emit AND no re-serialization needed, exit early
    # (preserves byte-identical output for small systems with nothing to add).
    if not new_conect_pairs and not needs_reserialize:
        return

    # Build the rewritten file lines.
    #   - ATOM/HETATM/TER: rewrite cols 7-11 with new_serial[atom_index] (or
    #     for TER, with the next-atom serial that mdtraj wrote)
    #   - CONECT (existing): rewrite each serial token via
    #     old_serial_first_index → new_serial map
    #   - new CONECT records: append before END using new_serial map
    line_idx_to_new_serial = {atom_index_to_lineno[ai]: new_serial[ai]
                              for ai in range(n_atoms)}
    rewritten = []
    next_ter_serial = ""  # populated as we encounter ATOM/HETATM lines
    for lno, line in enumerate(lines):
        if lno in line_idx_to_new_serial:
            ns = line_idx_to_new_serial[lno]
            rewritten.append(line[:6] + f"{ns:>5}" + line[11:])
            next_ter_serial = ns  # most-recent atom serial
        elif line.startswith("TER"):
            # Renumber TER serial to next_ter_serial + 1 (in the same encoding).
            # Per PDB convention TER's serial is one beyond the last ATOM.
            try:
                # Attempt to parse next_ter_serial as decimal, then hex if needed.
                if next_ter_serial.isdigit():
                    ter_serial_int = int(next_ter_serial) + 1
                else:
                    ter_serial_int = int(next_ter_serial, 16) - 0xA0000 + 100000 + 1
                ter_serial = _format_pdb_serial_v55(ter_serial_int)
            except (ValueError, AttributeError):
                ter_serial = next_ter_serial  # fallback: reuse last serial
            # Preserve TER columns 12+ (resname, chain, resseq, ...).
            rewritten.append(line[:6] + f"{ter_serial:>5}" + line[11:])
        elif line.startswith("CONECT"):
            # Remap each 5-char field (cols 6:11, 11:16, 16:21, 21:26, 26:31).
            # Only keep fields that resolve to a known atom under the
            # first-occurrence map; drop unresolvable tokens (rare wrap
            # artefact). If base atom unresolvable, drop the whole record.
            parts = []
            for pos in (6, 11, 16, 21, 26):
                tok = line[pos:pos + 5].strip() if pos + 5 <= len(line) else ""
                if not tok:
                    continue
                ai = old_serial_first_index.get(tok)
                if ai is None:
                    continue
                parts.append(new_serial[ai])
            if len(parts) >= 2:
                # Reformat: CONECT + 5-char fields.
                buf = "CONECT" + "".join(f"{p:>5}" for p in parts) + "\n"
                rewritten.append(buf)
            # else: drop the unresolvable CONECT line
        else:
            rewritten.append(line)

    # Build new CONECT records using new_serial map.
    new_conect_lines = []
    for idx1, idx2 in new_conect_pairs:
        s1 = new_serial[idx1]
        s2 = new_serial[idx2]
        new_conect_lines.append(f"CONECT{s1:>5}{s2:>5}\n")

    # Insert new_conect_lines before END
    if new_conect_lines:
        inserted = False
        final = []
        for line in rewritten:
            if line.startswith("END") and not inserted:
                final.extend(new_conect_lines)
                inserted = True
            final.append(line)
        if not inserted:
            final.extend(new_conect_lines)
        rewritten = final

    with open(pdb_path, "w", encoding="utf-8") as f:
        f.writelines(rewritten)


